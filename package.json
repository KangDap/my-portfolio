    "lenis": "^1.3.23",
    "lucide": "^1.3.0",
    "lucide-react": "^1.11.0",
    "motion": "^12.38.0",
    "next": "16.2.4",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-email": "6.1.4",
    "react-icons": "^5.6.0",
    "resend": "^6.12.3",
    "shadcn": "^4.5.0",
    "sonner": "^2.0.7",
